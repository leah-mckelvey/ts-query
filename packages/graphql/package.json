{
  "name": "@ts-query/graphql",
  "version": "1.0.0",
  "description": "GraphQL adapter for ts-query: fetch-based HTTP transport with TypedDocumentNode support and Automatic Persisted Queries (APQ)",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "keywords": [
    "graphql",
    "query",
    "apq",
    "persisted-queries"
  ],
  "dependencies": {
    "@ts-query/core": "1.0.0"
  },
  "peerDependencies": {
    "@graphql-typed-document-node/core": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "@graphql-typed-document-node/core": {
      "optional": true
    }
  },
  "license": "MIT"
}
